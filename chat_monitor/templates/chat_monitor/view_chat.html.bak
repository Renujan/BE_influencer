{% extends "wagtailadmin/base.html" %}

{% block titletag %}View Chat - {{ campaign.name }}{% endblock %}

{% block extra_css %}
<style>
    .chat-view-container {
        padding: 30px;
        background: #ffffff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        margin: 20px;
        font-family: 'Inter', system-ui, sans-serif;
    }

    .chat-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e5e7eb;
        padding-bottom: 20px;
        margin-bottom: 24px;
    }

    .campaign-info h2 {
        font-size: 1.4rem;
        font-weight: 700;
        margin: 0 0 6px 0;
        color: #111827;
    }

    .campaign-participants {
        font-size: 0.85rem;
        color: #4b5563;
        display: flex;
        gap: 16px;
    }

    .chat-timeline {
        display: flex;
        flex-direction: column;
        gap: 16px;
        max-height: 500px;
        overflow-y: auto;
        padding: 16px;
        background: #f9fafb;
        border-radius: 12px;
        border: 1px solid #f3f4f6;
        margin-bottom: 24px;
    }

    .msg-group {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        max-width: 75%;
    }

    .msg-group.brand {
        align-self: flex-start;
    }

    .msg-group.creator {
        align-self: flex-end;
        flex-direction: row-reverse;
    }

    .avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.8rem;
        color: #ffffff;
        flex-shrink: 0;
    }

    .avatar.brand {
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
    }

    .avatar.creator {
        background: linear-gradient(135deg, #ff6b6b 0%, #ee5253 100%);
    }

    .msg-content {
        display: flex;
        flex-direction: column;
    }

    .msg-group.creator .msg-content {
        align-items: flex-end;
    }

    .sender-name {
        font-size: 0.75rem;
        font-weight: 600;
        color: #4b5563;
        margin-bottom: 2px;
    }

    .bubble {
        padding: 10px 14px;
        border-radius: 12px;
        font-size: 0.85rem;
        line-height: 1.4;
    }

    .msg-group.brand .bubble {
        background: #ffffff;
        color: #1f2937;
        border: 1px solid #e5e7eb;
        border-top-left-radius: 2px;
    }

    .msg-group.creator .bubble {
        background: #4f46e5;
        color: #ffffff;
        border-top-right-radius: 2px;
    }

    .msg-timestamp {
        font-size: 0.65rem;
        color: #9ca3af;
        margin-top: 4px;
    }

    .attachment {
        margin-top: 6px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 8px;
        background: rgba(0, 0, 0, 0.05);
        border-radius: 4px;
        font-size: 0.75rem;
    }

    .msg-group.creator .attachment {
        background: rgba(255, 255, 255, 0.15);
        color: #ffffff;
    }

    .empty-state {
        text-align: center;
        padding: 40px;
        color: #9ca3af;
    }
</style>
{% endblock %}

{% block content %}
<div class="chat-view-container">
    <div class="chat-header">
        <div class="campaign-info">
            <h2>Workspace Chat History: {{ campaign.name }}</h2>
            <div class="campaign-participants">
                <span><strong>Business (Brand):</strong> {{ campaign.brand.username }}</span>
                <span><strong>Creator (Talent):</strong> {% if campaign.creator %}{{ campaign.creator.username }}{% else %}Unassigned{% endif %}</span>
            </div>
        </div>
        <div style="display: flex; gap: 8px;">
            <a href="{% url 'wagtailsnippets_campegin_campaign:inspect' campaign.id %}" class="button button-secondary" style="background-color: #06b6d4; color: white !important;">View Campaign</a>
            <a href="{% url 'download_campaign_pdf' campaign.id %}" class="button button-secondary" style="background-color: #2f54eb; color: white !important;">Download PDF</a>
            <a href="{% url 'chat_monitor_campaigns:index' %}" class="button button-secondary">Back to Chat Monitor</a>
        </div>
    </div>

    <div class="chat-timeline">
        {% for msg in messages %}
            <div class="msg-group {% if msg.sender == campaign.brand %}brand{% else %}creator{% endif %}">
                <div class="avatar {% if msg.sender == campaign.brand %}brand{% else %}creator{% endif %}">
                    {{ msg.sender.username|slice:":1"|upper }}
                </div>
                <div class="msg-content">
                    <span class="sender-name">{{ msg.sender.username }}</span>
                    <div class="bubble">
                        {{ msg.text }}
                        {% if msg.file_attachment %}
                            <br/>
                            <span class="attachment">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>
                                {{ msg.file_attachment }}
                            </span>
                        {% endif %}
                    </div>
                    <span class="msg-timestamp">{{ msg.time }}</span>
                </div>
            </div>
        {% empty %}
            <div class="empty-state">
                <p>No chat history available for this workspace.</p>
            </div>
        {% endfor %}
    </div>

    <div style="text-align: right; display: flex; justify-content: flex-end; gap: 8px;">
        <a href="{% url 'wagtailsnippets_campegin_campaign:inspect' campaign.id %}" class="button button-secondary" style="background-color: #06b6d4; color: white !important;">View Campaign</a>
        <a href="{% url 'download_campaign_pdf' campaign.id %}" class="button button-secondary" style="background-color: #2f54eb; color: white !important;">Download PDF</a>
        <a href="{% url 'chat_monitor_campaigns:index' %}" class="button button-secondary">Back to List</a>
    </div>
</div>
{% endblock %}
